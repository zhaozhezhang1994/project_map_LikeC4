# likec4-project-map — 环境变量示例(复制为 .env)
# Phase 0(静态地图)不需要任何变量。以下是 Phase 1(状态/控制适配器)将用到的:

# ── process-compose 适配器 (1.5A) ──
# 宿主机 process-compose REST 地址。Docker Desktop(Win/Mac)可经 host.docker.internal
# 回连宿主 127.0.0.1 服务; Linux host-gateway 够不到 loopback, 需服务听 0.0.0.0。
# PROCESS_COMPOSE_URL=http://host.docker.internal:18790

# ── Dagu 适配器 (后续, 当前 model 无对应节点) ──
# DAGU_URL=http://host.docker.internal:8101
# DAGU_AUTH=            # Basic base64(user:pass), 若 Dagu 开了鉴权

# ── 异常计数 (2A): 查 ClickHouse alerts_log → 节点红点 ──
# 不配则所有节点 anomaly_count=0 (染色/存活仍正常)。密码走 env 绝不进 config。
# CLICKHOUSE_URL=http://host.docker.internal:8123
# CLICKHOUSE_USER=default
# CLICKHOUSE_PASSWORD=
# CLICKHOUSE_DB=discord_pipeline
# ALERT_WINDOW_MIN=60          # 统计窗口: 数最近 N 分钟仍在告警的来源

# ── 控制接口(一键重启, 1B): 默认关。高危写操作, 开启需谨慎 ──
# 控制端点只走 nginx 的 127.0.0.1:7099 (LAN 不可达); 再加 token 鉴权 (纵深防御)。
# MAP_CONTROL_ENABLED=false        # 设 true 才启用; 不设=纯只读看板 (安全)
# MAP_OPERATOR_TOKEN=              # 开控制必设, ≥32 随机: python -c "import secrets;print(secrets.token_urlsafe(32))"
